# Backend Environment Variables (MUST STAY SECRET)
# These should ONLY be used in Supabase Edge Functions or server-side code

# Email Service (SENSITIVE)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@telagri.com

# Server Configuration
SITE_URL=https://dashboard.telagri.com

# Database/Project Configuration (used by CI/CD and Edge Functions)
SUPABASE_PROJECT_ID=
SUPABASE_DB_PASSWORD=

# Supabase Configuration for Edge Functions (no VITE_* here)
SUPABASE_URL=
# IMPORTANT: provide via Parameter Store/Secrets Manager in production
SUPABASE_SERVICE_ROLE_KEY=

# Third-party Service Keys (SENSITIVE)
# STRIPE_SECRET_KEY=sk_test_...
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# Internal API Keys (SENSITIVE)
# INTERNAL_API_SECRET=
# JWT_SECRET=

# ALE R parity service (ale-evaluate Edge Function -> algo.telagri.com)
# Shared HMAC secret; must match /opt/telagri/parity.env on the EC2 parity host.
# Unset/empty => ale-evaluate skips the R fan-out (TS-only). See specs/modules/ale.md.
PARITY_HMAC_SECRET=__PARITY_HMAC_SECRET__
# Optional; defaults to https://algo.telagri.com
# PARITY_URL=https://algo.telagri.com