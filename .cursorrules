## 📊 ADVANCED DATA PATTERNS

### Optimized Supabase Patterns
```typescript
// Type-safe database queries with RLS
class FarmerRepository {
  constructor(private supabase: SupabaseClient) {}

  async getFarmers(filters: FarmerFilters = {}): Promise<Result<Farmer[], DatabaseError>> {
    let query = this.supabase
      .from('farmers')
      .select(`
        *,
        bank:banks(name, id),
        latest_f100:f100_reports(
          id,
          reporting_period,
          created_at
        )
      `, { count: 'exact' });

    // Apply filters with proper SQL injection protection
    if (filters.bankId) query = query.eq('bank_id', filters.bankId);
    if (filters.status) query = query.eq('status', filters.status);
    if (filters.search) {
      query = query.ilike('name', `%${filters.search}%`);
    }

    const { data, error, count } = await query
      .order('created_at', { ascending: false })
      .range(filters.offset ?? 0, (filters.offset ?? 0) + (filters.limit ?? 50) - 1);

    if (error) {
      return { 
        success: false, 
        error: new DatabaseError('Failed to fetch farmers', error.code, error) 
      };
    }

    return { 
      success: true, 
      data: { farmers: data, totalCount: count ?? 0 } 
    };
  }

  // Batch operations for performance
  async createFarmers(farmers: Omit<Farmer, 'id'>[]): Promise<Result<Farmer[], ValidationError>> {
    const validatedFarmers = farmers.map(farmer => FarmerSchema.parse(farmer));
    
    const { data, error } = await this.supabase
      .from('farmers')
      .insert(validatedFarmers)
      .select();

    if (error) {
      return { success: false, error: new DatabaseError('Batch insert failed', error.code, error) };
    }

    return { success: true, data };
  }
}
```

### Advanced Caching Strategy
```typescript
// TanStack Query with advanced patterns
const queryClient = new QueryClient({
  defaultOptions: {
    queries: {
      staleTime: 5 * 60 * 1000, // 5 minutes
      gcTime: 10 * 60 * 1000, // 10 minutes (formerly cacheTime)
      retry: (failureCount, error) => {
        // Custom retry logic
        if (error instanceof ValidationError) return false;
        return failureCount < 3;
      },
      refetchOnWindowFocus: false,
      refetchOnReconnect: 'always'
    }
  }
});

// Custom hooks with proper cache management
function useFarmers(filters: FarmerFilters) {
  return useQuery({
    queryKey: ['farmers', filters],
    queryFn: async () => {
      const result = await farmerRepository.getFarmers(filters);
      if (!result.success) throw result.error;
      return result.data;
    },
    select: useCallback((data) => ({
      farmers: data.farmers,
      totalCount: data.totalCount,
      pages: Math.ceil(data.totalCount / (filters.limit ?? 50))
    }), [filters.limit])
  });
}

// Optimistic updates with proper error handling
function useCreateFarmer() {
  const queryClient = useQueryClient();
  
  return useMutation({
    mutationFn: farmerRepository.createFarmer,
    onMutate: async (newFarmer) => {
      // Cancel outgoing refetches
      await queryClient.cancelQueries({ queryKey: ['farmers'] });
      
      // Snapshot previous value
      const previousFarmers = queryClient.getQueryData(['farmers']);
      
      // Optimistically update
      queryClient.setQueryData(['farmers'], (old: any) => ({
        ...old,
        farmers: [...old.farmers, { ...newFarmer, id: `temp-${Date.now()}` }]
      }));
      
      return { previousFarmers };
    },
    onError: (err, newFarmer, context) => {
      // Rollback on error
      queryClient.setQueryData(['farmers'], context?.previousFarmers);
      
      toast({
        title: "Error creating farmer",
        description: err.message,
        variant: "destructive"
      });
    },
    onSettled: () => {
      queryClient.invalidateQueries({ queryKey: ['farmers'] });
    }
  });
}
```

