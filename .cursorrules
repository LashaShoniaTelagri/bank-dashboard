## 🔐 ENHANCED SECURITY PATTERNS

### Advanced Authentication & Authorization
```typescript
// Role-based access control with type safety
type UserRole = 'Administrator' | 'BankViewer' | 'ReadOnly';
type Permission = 'farmers:read' | 'farmers:write' | 'banks:read' | 'reports:generate';

const ROLE_PERMISSIONS: Record<UserRole, Permission[]> = {
  Administrator: ['farmers:read', 'farmers:write', 'banks:read', 'reports:generate'],
  BankViewer: ['farmers:read', 'reports:generate'],
  ReadOnly: ['farmers:read']
};

// Higher-order component for permission checking
function withPermission<T extends object>(
  Component: ComponentType<T>,
  requiredPermission: Permission
) {
  return function PermissionWrapper(props: T) {
    const { user } = useAuth();
    const hasPermission = useMemo(() => {
      if (!user?.role) return false;
      return ROLE_PERMISSIONS[user.role].includes(requiredPermission);
    }, [user?.role]);

    if (!hasPermission) {
      return <UnauthorizedMessage />;
    }

    return <Component {...props} />;
  };
}

// Usage
const ProtectedFarmerForm = withPermission(FarmerForm, 'farmers:write');
```

### Enhanced Input Validation
```typescript
// Comprehensive Zod schemas with business rules
const FarmerSchema = z.object({
  name: z.string()
    .min(2, 'Name must be at least 2 characters')
    .max(100, 'Name cannot exceed 100 characters')
    .regex(/^[a-zA-Z\s\-\']+$/, 'Name contains invalid characters'),
  
  email: z.string().email('Invalid email format'),
  
  phone: z.string()
    .regex(/^\+?[\d\s\-\(\)]+$/, 'Invalid phone number format')
    .transform(phone => phone.replace(/\D/g, '')), // Normalize phone numbers
    
  farmSize: z.number()
    .positive('Farm size must be positive')
    .max(10000, 'Farm size seems unrealistic')
    .transform(size => Math.round(size * 100) / 100), // Round to 2 decimals
    
  crops: z.array(z.enum(['wheat', 'corn', 'soybeans', 'other']))
    .min(1, 'At least one crop must be selected'),
    
  coordinates: z.object({
    latitude: z.number().min(-90).max(90),
    longitude: z.number().min(-180).max(180)
  }).optional()
}).refine(data => {
  // Custom business rule validation
  if (data.farmSize > 1000 && !data.coordinates) {
    return false; // Large farms must have coordinates
  }
  return true;
}, {
  message: 'Large farms (>1000 acres) must provide coordinates',
  path: ['coordinates']
});

type Farmer = z.infer<typeof FarmerSchema>;
```

