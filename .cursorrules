### Enhanced Error Handling Patterns
```typescript
// Custom error classes with proper inheritance
class TelAgriError extends Error {
  constructor(
    message: string,
    public code: string,
    public context?: Record<string, unknown>
  ) {
    super(message);
    this.name = 'TelAgriError';
  }
}

class ValidationError extends TelAgriError {
  constructor(message: string, public field: string, value: unknown) {
    super(message, 'VALIDATION_ERROR', { field, value });
    this.name = 'ValidationError';
  }
}

// Result pattern for better error handling
type Result<T, E = Error> = 
  | { success: true; data: T; error?: never }
  | { success: false; data?: never; error: E };

async function getFarmer(id: FarmerId): Promise<Result<Farmer, ValidationError>> {
  try {
    const farmer = await supabase.from('farmers').select('*').eq('id', id).single();
    if (farmer.error) throw new ValidationError('Farmer not found', 'id', id);
    return { success: true, data: farmer.data };
  } catch (error) {
    return { success: false, error: error as ValidationError };
  }
}

// Usage with proper error handling
const result = await getFarmer(farmerId);
if (!result.success) {
  toast({
    title: "Error",
    description: result.error.message,
    variant: "destructive"
  });
  return;
}
// TypeScript knows result.data is Farmer here
const farmer = result.data;
```

### Advanced Component Architecture
```typescript
// Compound component pattern with proper TypeScript
interface FarmerCardContextType {
  farmer: Farmer;
  isEditing: boolean;
  toggleEdit: () => void;
}

const FarmerCardContext = createContext<FarmerCardContextType | null>(null);

const FarmerCard = ({ children, farmer }: PropsWithChildren<{ farmer: Farmer }>) => {
  const [isEditing, setIsEditing] = useState(false);
  const toggleEdit = useCallback(() => setIsEditing(prev => !prev), []);
  
  const contextValue = useMemo(() => ({
    farmer,
    isEditing,
    toggleEdit
  }), [farmer, isEditing, toggleEdit]);

  return (
    <FarmerCardContext.Provider value={contextValue}>
      <Card className="farmer-card">{children}</Card>
    </FarmerCardContext.Provider>
  );
};

// Sub-components with context hook
const useFarmerCard = () => {
  const context = useContext(FarmerCardContext);
  if (!context) throw new Error('useFarmerCard must be used within FarmerCard');
  return context;
};

const FarmerCardHeader = ({ children }: PropsWithChildren) => {
  const { farmer, isEditing } = useFarmerCard();
  return (
    <CardHeader>
      {isEditing ? (
        <Input defaultValue={farmer.name} />
      ) : (
        <h3>{farmer.name}</h3>
      )}
      {children}
    </CardHeader>
  );
};
```

