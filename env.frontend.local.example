# Frontend Environment Variables — LOCAL DEVELOPMENT
# Copy to env.frontend.local (gitignored) and fill in the anon key from
# `npm run db:status` after starting the local stack.

# Application Configuration
VITE_APP_NAME=TelAgri Monitoring (Local)
VITE_APP_VERSION=2.0.0-local
VITE_APP_ENVIRONMENT=local

# Local Supabase (ports 64321-64329 per supabase/config.toml)
VITE_SUPABASE_URL=http://localhost:64321
# Run `npm run db:status` and paste the `anon key` value below.
VITE_SUPABASE_ANON_KEY=

# Local app URL (Vite default port)
VITE_APP_URL=http://localhost:8080

# Optional: Google Maps for local map features (use a dev-restricted key).
# Without this, map embeds will not render but the rest of the app works.
VITE_APP_GOOGLE_MAPS_API_KEY=

# Analytics / Monitoring — leave blank locally
VITE_APP_TAG_MANAGER_KEY=
VITE_APP_SMARTLOOK_KEY=
VITE_APP_SENTRY_DSN=
VITE_APP_CDN_URL=
VITE_APP_HYPERDX_API_KEY=
VITE_APP_HYPERDX_ENABLED=false
