# Backend Environment Variables — LOCAL DEVELOPMENT
# Copy to env.backend.local (gitignored). Most values come from `npm run db:status`.
# NEVER commit real values. NEVER include prod credentials here.

# Local Supabase
SUPABASE_URL=http://localhost:64321
# From `npm run db:status` (`service_role key`)
SUPABASE_SERVICE_ROLE_KEY=

# Local server URL
SITE_URL=http://localhost:8080

# Project/DB — local stack uses these defaults; usually no need to override
SUPABASE_PROJECT_ID=local
SUPABASE_DB_PASSWORD=postgres

# Email service — for local dev, either:
#   (a) use a dev SendGrid key (paste the dev value here); or
#   (b) leave blank and emails sent by Edge Functions will fail loudly.
# Inbucket runs on http://localhost:64324 if you want to redirect SMTP locally
# (requires Edge Function changes — out of scope for V1).
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@localhost

# Climate APIs — Open-Meteo is keyless; only set OPENWEATHER if a function needs it.
OPENWEATHER_MAP_API_KEY=
