# Frontend Environment Variables (Safe for public exposure)
# These will be embedded in the JavaScript bundle and visible to users

# Application Configuration
VITE_APP_NAME=TelAgri Monitoring
VITE_APP_VERSION=2.0.0
VITE_APP_ENVIRONMENT=production

# Supabase Configuration (Public keys only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Public Service URLs
VITE_APP_URL=https://dashboard.telagri.com

# Public API Keys (with domain restrictions)
VITE_APP_GOOGLE_MAPS_API_KEY=


# Analytics & Monitoring (Public keys)
VITE_APP_TAG_MANAGER_KEY=
VITE_APP_SMARTLOOK_KEY=
VITE_APP_SENTRY_DSN=
VITE_APP_CDN_URL=https://cdn.telagri.com/
VITE_APP_HYPERDX_API_KEY=
VITE_APP_HYPERDX_ENABLED=false